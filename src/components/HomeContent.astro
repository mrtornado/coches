---
import { desc, eq, isNotNull } from 'drizzle-orm';
import Layout from '../layouts/Layout.astro';
import SiteNav from './SiteNav.astro';
import SiteFooter from './SiteFooter.astro';
import { db, schema } from '../lib/db';
import { webSiteConfig } from '../config/webSiteConfig';
import { useTranslations, priceFormatter, translateTransmission, localizedPath, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const priceFmt = priceFormatter(lang);
const { company } = webSiteConfig;

const cars = await db
  .select()
  .from(schema.cars)
  .where(eq(schema.cars.available, true))
  .orderBy(desc(schema.cars.createdAt));

const brandRows = await db
  .selectDistinct({ brand: schema.cars.brand })
  .from(schema.cars)
  .where(isNotNull(schema.cars.brand));
const brands = brandRows.map((b) => b.brand).filter(Boolean) as string[];
const marquee = brands.length > 0 ? brands : ['Mercedes', 'BMW', 'Audi', 'Porsche', 'Range Rover'];

const featured = cars[0] ?? null;

const title =
  lang === 'en'
    ? 'Luxoria Drive — Luxury car rental in Benidorm'
    : 'Luxoria Drive — Alquiler de coches de lujo en Benidorm';

const usp = [
  { n: '01', t: t('usp1.title'), d: t('usp1.desc') },
  { n: '02', t: t('usp2.title'), d: `${company.address.street}, ${company.address.city}. ${t('usp2.tail')}` },
  { n: '03', t: t('usp3.title'), d: `${t('usp3.desc')} ${webSiteConfig.phone}.` },
];
---

<Layout title={title} chrome={false} theme="dark" htmlLang={lang} path="/">
  <div class="grain pointer-events-none fixed inset-0 z-50 opacity-[0.04] mix-blend-soft-light"></div>
  <div
    class="pointer-events-none fixed inset-0 -z-0"
    style="background:radial-gradient(120% 80% at 85% -10%, rgba(201,162,78,0.18), transparent 55%), radial-gradient(90% 60% at -10% 110%, rgba(201,162,78,0.10), transparent 50%);"
  >
  </div>

  <div class="relative z-10">
    <SiteNav lang={lang} path="/" />

    <!-- HERO -->
    <section class="mx-auto grid max-w-7xl grid-cols-1 items-center gap-12 px-6 pb-20 pt-10 lg:grid-cols-[1.05fr_0.95fr] lg:px-10 lg:pb-28 lg:pt-16">
      <div>
        <p class="reveal text-xs font-medium uppercase tracking-[0.45em] text-gold" style="animation-delay:.05s">
          {t('home.eyebrow')}
        </p>
        <h1
          class="reveal mt-6 font-display leading-[0.95] tracking-tight"
          style="animation-delay:.15s; font-size:clamp(2.5rem, 9vw, 7rem)"
        >
          {t('home.title1')}<br />
          <span class="italic text-gold">{t('home.titleAccent')}</span>
        </h1>
        <div class="reveal mt-8 h-px w-24 origin-left bg-gradient-to-r from-gold to-transparent line-grow" style="animation-delay:.4s"></div>
        <p class="reveal mt-8 max-w-md text-lg leading-relaxed text-taupe" style="animation-delay:.5s">
          {t('home.lead1')} <span class="text-cream">{t('home.leadAccent')}</span>
        </p>
        <div class="reveal mt-10 flex flex-wrap items-center gap-4" style="animation-delay:.62s">
          <a
            href="#flota"
            class="group relative inline-flex items-center gap-3 overflow-hidden rounded-full bg-gold px-7 py-3.5 text-sm font-semibold uppercase tracking-widest text-ink transition hover:bg-gold-light"
          >
            {t('home.viewFleet')}
            <span class="transition group-hover:translate-x-1">→</span>
          </a>
          <a
            href={webSiteConfig.phoneHref}
            class="inline-flex items-center gap-2 text-sm font-medium uppercase tracking-widest text-cream/80 transition hover:text-gold"
          >
            {t('home.bookByPhone')}
          </a>
        </div>
      </div>

      {
        featured && featured.imageUrl ? (
          <a href={localizedPath(lang, `/car/${featured.id}`)} class="reveal group relative block" style="animation-delay:.35s">
            <div class="relative overflow-hidden rounded-sm border border-cream/10">
              <img src={featured.imageUrl} alt={featured.title} class="aspect-[4/3] w-full object-cover transition duration-700 group-hover:scale-105" />
              <div class="absolute inset-0 bg-gradient-to-t from-ink/70 via-transparent to-transparent"></div>
              <div class="absolute bottom-0 left-0 right-0 flex items-end justify-between p-5">
                <div>
                  {featured.brand && <p class="text-[10px] uppercase tracking-[0.35em] text-gold">{featured.brand}</p>}
                  <p class="font-display text-2xl">{featured.title}</p>
                </div>
                <div class="text-right">
                  <p class="font-display text-3xl text-gold">{priceFmt.format(Number(featured.pricePerDay))}</p>
                  <p class="text-[10px] uppercase tracking-widest text-taupe">{t('home.perDay')}</p>
                </div>
              </div>
            </div>
            <span class="absolute -left-3 -top-3 hidden rounded-full border border-gold/40 bg-ink px-4 py-2 text-[10px] uppercase tracking-[0.3em] text-gold sm:block">
              {t('home.featured')}
            </span>
          </a>
        ) : (
          <div class="reveal relative aspect-[4/3] overflow-hidden rounded-sm border border-cream/10 bg-ink-soft" style="animation-delay:.35s">
            <div class="grain absolute inset-0 opacity-[0.05]"></div>
            <div class="flex h-full items-center justify-center font-display text-8xl text-cream/5">LD</div>
          </div>
        )
      }
    </section>

    <!-- MARQUEE -->
    <div class="fade-in relative overflow-hidden border-y border-cream/10 py-5" style="animation-delay:.8s">
      <div class="marquee-track flex w-max items-center gap-14 whitespace-nowrap">
        {
          [...marquee, ...marquee, ...marquee, ...marquee].map((b) => (
            <span class="flex items-center gap-14">
              <span class="font-display text-2xl italic text-cream/25">{b}</span>
              <span class="h-1 w-1 rounded-full bg-gold/50"></span>
            </span>
          ))
        }
      </div>
    </div>

    <!-- FLEET -->
    <section id="flota" class="mx-auto max-w-7xl scroll-mt-8 px-6 py-20 lg:px-10 lg:py-28">
      <div class="flex flex-wrap items-end justify-between gap-4">
        <div>
          <p class="text-xs font-medium uppercase tracking-[0.45em] text-gold">{t('fleet.label')}</p>
          <h2 class="mt-3 font-display text-5xl tracking-tight lg:text-6xl">{t('fleet.title')}</h2>
        </div>
        <p class="pb-2 text-sm text-taupe">
          {cars.length} {cars.length === 1 ? t('fleet.modelOne') : t('fleet.modelMany')}
        </p>
      </div>

      {
        cars.length === 0 ? (
          <div class="mt-12 rounded-sm border border-dashed border-cream/15 p-16 text-center">
            <p class="font-display text-3xl text-cream/70">{t('fleet.emptyTitle')}</p>
            <p class="mt-2 text-taupe">{t('fleet.emptySub')}</p>
            <a href={webSiteConfig.phoneHref} class="mt-6 inline-block text-sm uppercase tracking-widest text-gold hover:text-gold-light">
              {t('fleet.call')} · {webSiteConfig.phone}
            </a>
          </div>
        ) : (
          <div class="mt-12 grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
            {cars.map((car, i) => (
              <a
                href={localizedPath(lang, `/car/${car.id}`)}
                class="reveal group relative flex flex-col overflow-hidden rounded-sm border border-cream/10 bg-ink-soft transition duration-500 hover:-translate-y-1 hover:border-gold/40"
                style={`animation-delay:${Math.min(i, 8) * 70}ms`}
              >
                <div class="relative aspect-[4/3] overflow-hidden bg-ink-raise">
                  {car.imageUrl ? (
                    <img src={car.imageUrl} alt={car.title} loading="lazy" class="h-full w-full object-cover transition duration-700 group-hover:scale-105" />
                  ) : (
                    <div class="flex h-full items-center justify-center font-display text-5xl text-cream/10">Luxoria</div>
                  )}
                  <div class="absolute inset-0 bg-gradient-to-t from-ink-soft via-transparent to-transparent opacity-90"></div>
                  <span class="absolute right-4 top-4 font-display text-sm text-cream/30">{String(i + 1).padStart(2, '0')}</span>
                </div>

                <div class="flex flex-1 flex-col p-6">
                  {car.brand && <p class="text-[10px] uppercase tracking-[0.35em] text-gold">{car.brand}</p>}
                  <h3 class="mt-1 font-display text-2xl leading-tight">{car.title}</h3>

                  <div class="mt-4 flex flex-wrap gap-x-4 gap-y-1 text-xs text-taupe">
                    {car.seats && <span>{car.seats} {t('spec.seats')}</span>}
                    {car.seats && (car.transmission || car.fuel) && <span class="text-cream/15">/</span>}
                    {car.transmission && <span>{translateTransmission(car.transmission, lang)}</span>}
                    {car.transmission && car.fuel && <span class="text-cream/15">/</span>}
                    {car.fuel && <span>{car.fuel}</span>}
                  </div>
                  <p class="mt-2 text-xs text-gold/80">
                    {car.kmUnlimited ? t('km.unlimitedShort') : `${car.kmPerDay} ${t('km.perDayShort')}`}
                  </p>

                  <div class="mt-6 flex items-end justify-between border-t border-cream/10 pt-5">
                    <div>
                      <span class="font-display text-3xl text-gold">{priceFmt.format(Number(car.pricePerDay))}</span>
                      <span class="ml-1 text-xs text-taupe">{t('car.perDay')}</span>
                    </div>
                    <span class="inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-widest text-cream transition group-hover:text-gold">
                      {t('card.reserve')}
                      <span class="transition group-hover:translate-x-1">→</span>
                    </span>
                  </div>
                </div>
              </a>
            ))}
          </div>
        )
      }
    </section>

    <!-- WHY -->
    <section class="border-t border-cream/10">
      <div class="mx-auto grid max-w-7xl grid-cols-1 gap-px bg-cream/10 md:grid-cols-3">
        {
          usp.map((f) => (
            <div class="bg-ink px-8 py-12 lg:px-10 lg:py-16">
              <span class="font-display text-4xl text-gold/70">{f.n}</span>
              <h3 class="mt-6 font-display text-2xl">{f.t}</h3>
              <p class="mt-3 text-sm leading-relaxed text-taupe">{f.d}</p>
            </div>
          ))
        }
      </div>
    </section>

    <SiteFooter lang={lang} />
  </div>
</Layout>
