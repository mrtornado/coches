---
import { webSiteConfig } from '../config/webSiteConfig';
import { useTranslations, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const { company } = webSiteConfig;
const year = new Date().getFullYear();
---

<footer class="relative overflow-hidden border-t border-cream/10">
  <div
    class="pointer-events-none absolute inset-0"
    style="background:radial-gradient(80% 120% at 50% 140%, rgba(201,162,78,0.16), transparent 60%);"
  >
  </div>
  <div class="relative mx-auto max-w-7xl px-6 py-24 text-center lg:px-10 lg:py-32">
    <p class="text-xs font-medium uppercase tracking-[0.45em] text-gold">{t('footer.eyebrow')}</p>
    <h2 class="mx-auto mt-6 max-w-3xl font-display text-5xl leading-tight tracking-tight lg:text-7xl">
      {t('footer.title1')} <span class="italic text-gold">{t('footer.titleAccent')}</span>.
    </h2>
    <a
      href={webSiteConfig.phoneHref}
      class="mt-10 inline-flex items-center gap-3 rounded-full bg-gold px-9 py-4 text-sm font-semibold uppercase tracking-widest text-ink transition hover:bg-gold-light"
    >
      {webSiteConfig.phone}
    </a>

    <div class="mt-20 flex flex-col items-center justify-between gap-6 border-t border-cream/10 pt-10 text-sm text-taupe sm:flex-row sm:text-left">
      <div>
        <span class="font-display text-lg text-cream">{webSiteConfig.name}</span>
        <p class="mt-1 text-xs">{company.fullAddress}</p>
      </div>
      <div class="flex items-center gap-6 text-xs uppercase tracking-widest">
        <span>&copy; {year} {webSiteConfig.name}</span>
        <a href="/admin" class="text-taupe/50 transition hover:text-gold">{t('footer.admin')}</a>
      </div>
    </div>
  </div>
</footer>
