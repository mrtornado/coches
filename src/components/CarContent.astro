---
import { asc, eq } from 'drizzle-orm';
import Layout from '../layouts/Layout.astro';
import SiteNav from './SiteNav.astro';
import SiteFooter from './SiteFooter.astro';
import BookingDates from './BookingDates.tsx';
import { db, schema } from '../lib/db';
import { webSiteConfig } from '../config/webSiteConfig';
import { useTranslations, priceFormatter, translateTransmission, localizedPath, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
  id: number;
}
const { lang, id } = Astro.props;
const t = useTranslations(lang);
const priceFmt = priceFormatter(lang);

let car = null;
if (Number.isInteger(id) && id > 0) {
  const rows = await db.select().from(schema.cars).where(eq(schema.cars.id, id)).limit(1);
  car = rows[0] ?? null;
}

if (!car) {
  return new Response(lang === 'en' ? 'Car not found' : 'Coche no encontrado', { status: 404 });
}

const images = await db
  .select({ url: schema.carImages.url })
  .from(schema.carImages)
  .where(eq(schema.carImages.carId, id))
  .orderBy(asc(schema.carImages.position), asc(schema.carImages.id));
const gallery = images.length > 0 ? images.map((i) => i.url) : car.imageUrl ? [car.imageUrl] : [];

const description = lang === 'en' ? car.descriptionEn || car.description : car.description;

const booked = Astro.url.searchParams.get('ok') === '1';
const { company } = webSiteConfig;
const price = priceFmt.format(Number(car.pricePerDay));

const waNumber = webSiteConfig.phoneHref.replace(/[^0-9]/g, '');
const waMsg =
  lang === 'en'
    ? `Hi, I'm interested in the ${car.title} (${price}/day). Is it available?`
    : `Hola, me interesa el ${car.title} (${price}/día). ¿Está disponible?`;
const waHref = `https://wa.me/${waNumber}?text=${encodeURIComponent(waMsg)}`;

const specs = [
  car.seats ? { label: t('spec.seatsLabel'), value: String(car.seats) } : null,
  car.transmission ? { label: t('spec.transmission'), value: translateTransmission(car.transmission, lang) } : null,
  car.fuel ? { label: t('spec.fuel'), value: car.fuel } : null,
].filter(Boolean) as { label: string; value: string }[];

const fieldClass =
  'mt-1 w-full rounded-sm border border-cream/15 bg-ink px-3 py-2.5 text-sm text-cream placeholder-taupe/50 outline-none transition focus:border-gold/60';
---

<Layout title={`${car.title} — Luxoria Drive`} chrome={false} theme="dark" htmlLang={lang} path={`/car/${id}`}>
  <div class="grain pointer-events-none fixed inset-0 z-50 opacity-[0.04] mix-blend-soft-light"></div>
  <div
    class="pointer-events-none fixed inset-0 -z-0"
    style="background:radial-gradient(110% 70% at 90% -10%, rgba(201,162,78,0.14), transparent 55%);"
  >
  </div>

  <div class="relative z-10">
    <SiteNav lang={lang} path={`/car/${id}`} />

    <div class="mx-auto max-w-7xl px-6 pb-24 pt-4 lg:px-10">
      <a
        href={localizedPath(lang, '/')}
        class="group inline-flex items-center gap-2 text-xs uppercase tracking-[0.3em] text-taupe transition hover:text-gold"
      >
        <span class="transition group-hover:-translate-x-1">←</span> {t('car.back')}
      </a>

      <div class="mt-8 grid grid-cols-1 gap-12 lg:grid-cols-2">
        <!-- GALLERY -->
        <div class="reveal">
          <div class="relative overflow-hidden rounded-sm border border-cream/10 bg-ink-soft">
            {
              gallery.length > 0 ? (
                <img id="mainImg" src={gallery[0]} alt={car.title} class="aspect-[4/3] w-full object-cover" />
              ) : (
                <div class="flex aspect-[4/3] items-center justify-center font-display text-7xl text-cream/10">Luxoria</div>
              )
            }
          </div>
          {
            gallery.length > 1 && (
              <div class="mt-3 grid grid-cols-5 gap-2">
                {gallery.map((url, i) => (
                  <button
                    type="button"
                    data-src={url}
                    class={`gallery-thumb aspect-square overflow-hidden rounded-sm border-2 transition ${i === 0 ? 'border-gold' : 'border-transparent hover:border-cream/30'}`}
                  >
                    <img src={url} alt="" class="h-full w-full object-cover" />
                  </button>
                ))}
              </div>
            )
          }
        </div>

        <!-- INFO + CONTACT -->
        <div class="reveal" style="animation-delay:.12s">
          {car.brand && <p class="text-xs uppercase tracking-[0.4em] text-gold">{car.brand}</p>}
          <h1 class="mt-3 font-display text-5xl leading-[0.95] tracking-tight lg:text-6xl">{car.title}</h1>

          <div class="mt-6 flex items-baseline gap-2">
            <span class="font-display text-4xl text-gold">{price}</span>
            <span class="text-sm text-taupe">{t('car.perDay')}</span>
          </div>
          <div class="mt-3">
            <span class="inline-block rounded-full border border-gold/30 px-3 py-1 text-[11px] uppercase tracking-widest text-gold">
              {car.kmUnlimited ? t('km.unlimitedLong') : `${car.kmPerDay} ${t('km.perDayLong')}`}
            </span>
          </div>

          {
            specs.length > 0 && (
              <div class="mt-8 grid grid-cols-3 divide-x divide-cream/10 rounded-sm border border-cream/10">
                {specs.map((s) => (
                  <div class="px-4 py-4 text-center">
                    <p class="text-[10px] uppercase tracking-[0.25em] text-taupe">{s.label}</p>
                    <p class="mt-1 font-display text-lg">{s.value}</p>
                  </div>
                ))}
              </div>
            )
          }

          {description && <p class="mt-6 whitespace-pre-line leading-relaxed text-taupe">{description}</p>}

          <!-- CONTACT CARD -->
          <div class="mt-10 rounded-sm border border-cream/10 bg-ink-soft p-6 lg:p-8">
            {
              booked ? (
                <div class="text-center">
                  <p class="font-display text-2xl text-gold">{t('book.sentTitle')}</p>
                  <p class="mt-2 text-sm text-taupe">{t('book.sentSub')}</p>
                  <a
                    href={webSiteConfig.phoneHref}
                    class="mt-5 inline-flex items-center gap-2 rounded-full bg-gold px-7 py-3 text-sm font-semibold uppercase tracking-widest text-ink transition hover:bg-gold-light"
                  >
                    {webSiteConfig.phone}
                  </a>
                </div>
              ) : (
                <>
                  <h2 class="font-display text-2xl">{t('book.title')}</h2>
                  <p class="mt-1 text-sm text-taupe">{t('book.sub')}</p>

                  <div class="mt-5 grid grid-cols-1 gap-3 sm:grid-cols-2">
                    <a
                      href={webSiteConfig.phoneHref}
                      class="flex items-center justify-center gap-2 rounded-sm bg-gold px-5 py-3.5 text-sm font-semibold uppercase tracking-widest text-ink transition hover:bg-gold-light"
                    >
                      <span>📞</span> {webSiteConfig.phone}
                    </a>
                    <a
                      href={waHref}
                      target="_blank"
                      rel="noopener"
                      class="flex items-center justify-center gap-2 rounded-sm border border-cream/20 px-5 py-3.5 text-sm font-semibold uppercase tracking-widest text-cream transition hover:border-gold/60 hover:text-gold"
                    >
                      <span>💬</span> WhatsApp
                    </a>
                  </div>

                  <div class="my-6 flex items-center gap-4 text-[10px] uppercase tracking-[0.3em] text-taupe/60">
                    <span class="h-px flex-1 bg-cream/10" />
                    {t('book.or')}
                    <span class="h-px flex-1 bg-cream/10" />
                  </div>

                  <form method="post" action="/api/bookings/create" class="space-y-3">
                    <input type="hidden" name="carId" value={car.id} />
                    <input type="hidden" name="lang" value={lang} />
                    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
                      <label class="block">
                        <span class="text-xs uppercase tracking-widest text-taupe">{t('book.name')} *</span>
                        <input name="name" required class={fieldClass} />
                      </label>
                      <label class="block">
                        <span class="text-xs uppercase tracking-widest text-taupe">{t('book.phone')} *</span>
                        <input name="phone" required class={fieldClass} />
                      </label>
                    </div>
                    <label class="block">
                      <span class="text-xs uppercase tracking-widest text-taupe">{t('book.email')}</span>
                      <input name="email" type="email" class={fieldClass} />
                    </label>
                    <BookingDates client:load lang={lang} />
                    <label class="block">
                      <span class="text-xs uppercase tracking-widest text-taupe">{t('book.message')}</span>
                      <textarea name="message" rows="3" class={fieldClass} />
                    </label>
                    <button
                      type="submit"
                      class="w-full rounded-sm bg-cream px-5 py-3 text-sm font-semibold uppercase tracking-widest text-ink transition hover:bg-gold-light"
                    >
                      {t('book.send')}
                    </button>
                  </form>
                </>
              )
            }

            <div class="mt-6 flex items-start gap-2 border-t border-cream/10 pt-5 text-xs text-taupe">
              <span class="text-gold">📍</span>
              <span>{t('book.pickupAt')} {company.address.street}, {company.address.city} ({company.address.province})</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <SiteFooter lang={lang} />
  </div>

  <script is:inline>
    (() => {
      const main = document.getElementById('mainImg');
      const thumbs = document.querySelectorAll('.gallery-thumb');
      thumbs.forEach((btn) => {
        btn.addEventListener('click', () => {
          const src = btn.getAttribute('data-src');
          if (src && main) main.setAttribute('src', src);
          thumbs.forEach((b) => {
            b.classList.remove('border-gold');
            b.classList.add('border-transparent');
          });
          btn.classList.remove('border-transparent');
          btn.classList.add('border-gold');
        });
      });
    })();
  </script>
</Layout>
