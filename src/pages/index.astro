---
import { desc, eq } from 'drizzle-orm';
import Layout from '../layouts/Layout.astro';
import { db, schema } from '../lib/db';

const cars = await db
  .select()
  .from(schema.cars)
  .where(eq(schema.cars.available, true))
  .orderBy(desc(schema.cars.createdAt));

const priceFmt = new Intl.NumberFormat('es-ES', {
  style: 'currency',
  currency: 'EUR',
  maximumFractionDigits: 0,
});
---

<Layout title="Alquiler de Coches">
  <div class="mb-8">
    <h1 class="text-3xl font-bold tracking-tight">Nuestra flota</h1>
    <p class="mt-1 text-slate-500">Elige tu coche y reserva sin pagos online.</p>
  </div>

  {
    cars.length === 0 ? (
      <div class="rounded-lg border border-dashed border-slate-300 bg-white p-12 text-center text-slate-500">
        Todavía no hay coches disponibles. Vuelve pronto.
      </div>
    ) : (
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {cars.map((car) => (
          <a
            href={`/car/${car.id}`}
            class="group flex flex-col overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm transition hover:shadow-md"
          >
            <div class="aspect-video w-full overflow-hidden bg-slate-100">
              {car.imageUrl ? (
                <img
                  src={car.imageUrl}
                  alt={car.title}
                  class="h-full w-full object-cover transition group-hover:scale-105"
                  loading="lazy"
                />
              ) : (
                <div class="flex h-full w-full items-center justify-center text-4xl text-slate-300">
                  🚗
                </div>
              )}
            </div>
            <div class="flex flex-1 flex-col p-4">
              <div class="flex items-start justify-between gap-2">
                <div>
                  {car.brand && (
                    <p class="text-xs font-medium uppercase tracking-wide text-slate-400">
                      {car.brand}
                    </p>
                  )}
                  <h2 class="font-semibold leading-tight">{car.title}</h2>
                </div>
                <div class="whitespace-nowrap text-right">
                  <span class="text-lg font-bold text-blue-600">
                    {priceFmt.format(Number(car.pricePerDay))}
                  </span>
                  <span class="block text-xs text-slate-400">/ día</span>
                </div>
              </div>
              <div class="mt-3 flex flex-wrap gap-2 text-xs text-slate-500">
                {car.seats && <span class="rounded bg-slate-100 px-2 py-1">👤 {car.seats} plazas</span>}
                {car.transmission && <span class="rounded bg-slate-100 px-2 py-1">⚙️ {car.transmission}</span>}
                {car.fuel && <span class="rounded bg-slate-100 px-2 py-1">⛽ {car.fuel}</span>}
              </div>
              <span class="mt-4 inline-block rounded-lg bg-blue-600 px-4 py-2 text-center text-sm font-medium text-white transition group-hover:bg-blue-700">
                Ver y reservar
              </span>
            </div>
          </a>
        ))}
      </div>
    )
  }
</Layout>
