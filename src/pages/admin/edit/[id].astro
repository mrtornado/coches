---
import { eq } from 'drizzle-orm';
import Layout from '../../../layouts/Layout.astro';
import CarForm from '../../../components/CarForm.tsx';
import { db, schema } from '../../../lib/db';
import { isAuthed } from '../../../lib/auth';

if (!isAuthed(Astro.cookies)) {
  return Astro.redirect('/admin');
}

const id = Number(Astro.params.id);
let car = null;
if (Number.isInteger(id) && id > 0) {
  const rows = await db.select().from(schema.cars).where(eq(schema.cars.id, id)).limit(1);
  car = rows[0] ?? null;
}

if (!car) {
  return new Response('Coche no encontrado', { status: 404 });
}
---

<Layout title={`Editar — ${car.title}`}>
  <a href="/admin" class="mb-6 inline-block text-sm text-slate-500 hover:text-slate-900">&larr; Volver al panel</a>

  <h1 class="mb-6 text-2xl font-bold">Editar coche</h1>

  <section class="rounded-xl border border-slate-200 bg-white p-6">
    <CarForm client:load action="/api/cars/update" submitLabel="Guardar cambios" car={car} />
  </section>
</Layout>
