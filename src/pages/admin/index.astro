---
import { desc } from 'drizzle-orm';
import Layout from '../../layouts/Layout.astro';
import CarForm from '../../components/CarForm.tsx';
import { db, schema } from '../../lib/db';
import { isAuthed } from '../../lib/auth';

const authed = isAuthed(Astro.cookies);
const loginError = Astro.url.searchParams.get('error') === '1';

let cars: (typeof schema.cars.$inferSelect)[] = [];
let bookings: (typeof schema.bookings.$inferSelect)[] = [];

if (authed) {
  cars = await db.select().from(schema.cars).orderBy(desc(schema.cars.createdAt));
  bookings = await db
    .select()
    .from(schema.bookings)
    .orderBy(desc(schema.bookings.createdAt))
    .limit(50);
}

const priceFmt = new Intl.NumberFormat('es-ES', {
  style: 'currency',
  currency: 'EUR',
  maximumFractionDigits: 0,
});
---

<Layout title="Admin">
  {
    !authed ? (
      <div class="mx-auto max-w-sm">
        <h1 class="text-2xl font-bold">Acceso admin</h1>
        <form method="post" action="/api/login" class="mt-6 space-y-4">
          {loginError && (
            <div class="rounded-lg bg-red-50 p-3 text-sm text-red-700">Contraseña incorrecta.</div>
          )}
          <label class="block">
            <span class="text-sm text-slate-600">Contraseña</span>
            <input
              name="password"
              type="password"
              required
              autofocus
              class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-blue-500 focus:outline-none"
            />
          </label>
          <button type="submit" class="w-full rounded-lg bg-blue-600 px-4 py-2.5 text-sm font-medium text-white hover:bg-blue-700">
            Entrar
          </button>
        </form>
      </div>
    ) : (
      <div class="space-y-10">
        <div class="flex items-center justify-between">
          <h1 class="text-2xl font-bold">Panel de administración</h1>
          <form method="post" action="/api/logout">
            <button class="text-sm text-slate-500 hover:text-slate-900">Cerrar sesión</button>
          </form>
        </div>

        <section class="rounded-xl border border-slate-200 bg-white p-6">
          <h2 class="mb-4 text-lg font-semibold">Añadir coche</h2>
          <CarForm client:load action="/api/cars/create" submitLabel="Añadir coche" />
        </section>

        <section>
          <h2 class="mb-4 text-lg font-semibold">Coches ({cars.length})</h2>
          {cars.length === 0 ? (
            <p class="text-sm text-slate-500">Todavía no hay coches.</p>
          ) : (
            <div class="overflow-hidden rounded-xl border border-slate-200 bg-white">
              <table class="w-full text-sm">
                <thead class="bg-slate-50 text-left text-slate-500">
                  <tr>
                    <th class="p-3 font-medium">Coche</th>
                    <th class="p-3 font-medium">Precio/día</th>
                    <th class="p-3 font-medium">Estado</th>
                    <th class="p-3 font-medium text-right">Acciones</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                  {cars.map((car) => (
                    <tr>
                      <td class="p-3">
                        <div class="flex items-center gap-3">
                          <div class="h-10 w-16 shrink-0 overflow-hidden rounded bg-slate-100">
                            {car.imageUrl ? (
                              <img src={car.imageUrl} alt={car.title} class="h-full w-full object-cover" />
                            ) : (
                              <div class="flex h-full w-full items-center justify-center text-slate-300">🚗</div>
                            )}
                          </div>
                          <div>
                            <p class="font-medium">{car.title}</p>
                            {car.brand && <p class="text-xs text-slate-400">{car.brand}</p>}
                          </div>
                        </div>
                      </td>
                      <td class="p-3">{priceFmt.format(Number(car.pricePerDay))}</td>
                      <td class="p-3">
                        {car.available ? (
                          <span class="rounded-full bg-green-100 px-2 py-0.5 text-xs text-green-700">Disponible</span>
                        ) : (
                          <span class="rounded-full bg-slate-200 px-2 py-0.5 text-xs text-slate-600">Oculto</span>
                        )}
                      </td>
                      <td class="p-3">
                        <div class="flex justify-end gap-2">
                          <a
                            href={`/admin/edit/${car.id}`}
                            class="rounded border border-slate-300 px-2.5 py-1 text-xs hover:bg-slate-50"
                          >
                            Editar
                          </a>
                          <form method="post" action="/api/cars/toggle">
                            <input type="hidden" name="id" value={car.id} />
                            <button class="rounded border border-slate-300 px-2.5 py-1 text-xs hover:bg-slate-50">
                              {car.available ? 'Ocultar' : 'Mostrar'}
                            </button>
                          </form>
                          <form method="post" action="/api/cars/delete" onsubmit="return confirm('¿Eliminar este coche?')">
                            <input type="hidden" name="id" value={car.id} />
                            <button class="rounded border border-red-200 px-2.5 py-1 text-xs text-red-600 hover:bg-red-50">
                              Eliminar
                            </button>
                          </form>
                        </div>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}
        </section>

        <section>
          <h2 class="mb-4 text-lg font-semibold">Solicitudes de reserva ({bookings.length})</h2>
          {bookings.length === 0 ? (
            <p class="text-sm text-slate-500">Todavía no hay solicitudes.</p>
          ) : (
            <div class="overflow-hidden rounded-xl border border-slate-200 bg-white">
              <table class="w-full text-sm">
                <thead class="bg-slate-50 text-left text-slate-500">
                  <tr>
                    <th class="p-3 font-medium">Cliente</th>
                    <th class="p-3 font-medium">Contacto</th>
                    <th class="p-3 font-medium">Fechas</th>
                    <th class="p-3 font-medium">Coche #</th>
                    <th class="p-3 font-medium">Mensaje</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                  {bookings.map((b) => (
                    <tr>
                      <td class="p-3 font-medium">{b.name}</td>
                      <td class="p-3 text-slate-600">
                        <div>{b.phone}</div>
                        {b.email && <div class="text-xs text-slate-400">{b.email}</div>}
                      </td>
                      <td class="p-3 text-slate-600">
                        {b.startDate || '—'} {b.endDate ? `→ ${b.endDate}` : ''}
                      </td>
                      <td class="p-3 text-slate-600">{b.carId ?? '—'}</td>
                      <td class="p-3 max-w-xs text-slate-600">{b.message}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}
        </section>
      </div>
    )
  }
</Layout>
