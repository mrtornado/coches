---
import { asc, desc } from 'drizzle-orm';
import Layout from '../../layouts/Layout.astro';
import AdminCars, { type AdminCar } from '../../components/AdminCars';
import { db, schema } from '../../lib/db';
import { isAuthed } from '../../lib/auth';

const authed = isAuthed(Astro.cookies);
const loginError = Astro.url.searchParams.get('error') === '1';
const lockedMins = Astro.url.searchParams.get('locked');
const saved = Astro.url.searchParams.get('ok') === '1';

let carsForClient: AdminCar[] = [];
let bookings: (typeof schema.bookings.$inferSelect)[] = [];

if (authed) {
  const carRows = await db.select().from(schema.cars).orderBy(desc(schema.cars.createdAt));

  const imgRows = await db
    .select({ id: schema.carImages.id, carId: schema.carImages.carId, url: schema.carImages.url })
    .from(schema.carImages)
    .orderBy(asc(schema.carImages.position), asc(schema.carImages.id));

  const byCar = new Map<number, { id: number; url: string }[]>();
  for (const im of imgRows) {
    const arr = byCar.get(im.carId) ?? [];
    arr.push({ id: im.id, url: im.url });
    byCar.set(im.carId, arr);
  }

  carsForClient = carRows.map((c) => ({
    id: c.id,
    title: c.title,
    brand: c.brand,
    pricePerDay: c.pricePerDay,
    seats: c.seats,
    transmission: c.transmission,
    fuel: c.fuel,
    kmUnlimited: c.kmUnlimited,
    kmPerDay: c.kmPerDay,
    description: c.description,
    descriptionEn: c.descriptionEn,
    imageUrl: c.imageUrl,
    available: c.available,
    images: byCar.get(c.id) ?? [],
  }));

  bookings = await db
    .select()
    .from(schema.bookings)
    .orderBy(desc(schema.bookings.createdAt))
    .limit(50);
}
---

<Layout title="Admin — Luxoria Drive">
  {
    !authed ? (
      <div class="mx-auto max-w-sm py-8">
        <h1 class="font-display text-3xl">Acceso admin</h1>
        <form method="post" action="/api/login" class="mt-6 space-y-4">
          {lockedMins ? (
            <div class="rounded-lg bg-amber-50 p-3 text-sm text-amber-800">
              🔒 Demasiados intentos fallidos. Vuelve a intentarlo en {lockedMins}{' '}
              {Number(lockedMins) === 1 ? 'minuto' : 'minutos'}.
            </div>
          ) : (
            loginError && (
              <div class="rounded-lg bg-red-50 p-3 text-sm text-red-700">Contraseña incorrecta.</div>
            )
          )}
          <label class="block">
            <span class="text-sm text-slate-600">Contraseña</span>
            <input
              name="password"
              type="password"
              required
              autofocus
              class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-blue-500 focus:outline-none"
            />
          </label>
          <button type="submit" class="w-full rounded-lg bg-blue-600 px-4 py-2.5 text-sm font-medium text-white hover:bg-blue-700">
            Entrar
          </button>
        </form>
      </div>
    ) : (
      <div class="space-y-10">
        <div class="flex items-center justify-between">
          <h1 class="font-display text-3xl">Panel de administración</h1>
          <form method="post" action="/api/logout">
            <button class="text-sm text-slate-500 hover:text-slate-900">Cerrar sesión</button>
          </form>
        </div>

        {saved && (
          <div class="rounded-lg border border-green-200 bg-green-50 p-3 text-sm text-green-800">
            ✅ Cambios guardados.
          </div>
        )}

        <section>
          <AdminCars client:load cars={carsForClient} />
        </section>

        <section>
          <h2 class="mb-4 text-lg font-semibold">Solicitudes de reserva ({bookings.length})</h2>
          {bookings.length === 0 ? (
            <p class="text-sm text-slate-500">Todavía no hay solicitudes.</p>
          ) : (
            <div class="space-y-3">
              {bookings.map((b) => {
                const carTitle = carsForClient.find((c) => c.id === b.carId)?.title;
                return (
                  <div class="rounded-xl border border-slate-200 bg-white p-4">
                    <div class="flex flex-wrap items-start justify-between gap-2">
                      <div class="min-w-0">
                        <p class="font-medium">{b.name}</p>
                        <p class="mt-0.5 text-sm text-slate-500">
                          <a href={`tel:${b.phone}`} class="hover:text-slate-800">{b.phone}</a>
                          {b.email && (
                            <>
                              {' · '}
                              <a href={`mailto:${b.email}`} class="hover:text-slate-800">{b.email}</a>
                            </>
                          )}
                        </p>
                      </div>
                      <span class="rounded-full bg-slate-100 px-2.5 py-1 text-xs text-slate-600">
                        🚗 {carTitle ?? (b.carId ? `#${b.carId}` : 'coche eliminado')}
                      </span>
                    </div>

                    {(b.startDate || b.endDate) && (
                      <p class="mt-2 text-sm text-slate-600">
                        📅 {b.startDate || '—'} {b.endDate ? `→ ${b.endDate}` : ''}
                      </p>
                    )}
                    {b.message && (
                      <p class="mt-2 whitespace-pre-line rounded-lg bg-slate-50 p-3 text-sm text-slate-600">{b.message}</p>
                    )}

                    <div class="mt-3 flex justify-end border-t border-slate-100 pt-3">
                      <form
                        method="post"
                        action="/api/bookings/delete"
                        onsubmit="return confirm('¿Eliminar esta solicitud?')"
                      >
                        <input type="hidden" name="id" value={b.id} />
                        <button class="rounded-lg border border-red-200 px-3 py-1.5 text-sm text-red-600 transition hover:bg-red-50">
                          Eliminar
                        </button>
                      </form>
                    </div>
                  </div>
                );
              })}
            </div>
          )}
        </section>
      </div>
    )
  }
</Layout>
