# ---- App ----
# HOST is NOT needed: the server binds to 0.0.0.0 by default (see astro.config.mjs).
# PORT is optional: defaults to 8080. Set it only if you want a specific port.
# PORT=8080
# Long random string used to sign the admin session cookie
SESSION_SECRET=change-me-to-a-long-random-string
# Password for the /admin area
ADMIN_PASSWORD=change-me
# Brute-force protection: lock an IP after N failed logins, for M minutes
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MINUTES=120

# ---- Postgres (Coolify service) ----
DATABASE_URL=postgres://user:pass@host:5432/coches
# Set true if your Postgres requires SSL (many managed providers do)
DATABASE_SSL=false

# ---- S3 / object storage (AWS S3, Cloudflare R2, or MinIO) ----
# Leave S3_ENDPOINT blank for AWS S3. For R2: https://<accountid>.r2.cloudflarestorage.com
S3_ENDPOINT=
# AWS: e.g. eu-west-1  |  R2: auto
S3_REGION=auto
S3_BUCKET=coches
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# true for MinIO / path-style buckets
S3_FORCE_PATH_STYLE=false
# Public base URL where uploaded objects are served (no trailing slash)
# e.g. https://cdn.example.com  or  R2 public bucket URL
S3_PUBLIC_URL=

# ---- SMTP (booking form emails) ----
# Booking notifications are sent to MAIL_TO (defaults to webSiteConfig.email), with Reply-To = customer's email.
SMTP_HOST=mail.vizo.live
SMTP_PORT=587
# true only for port 465 (implicit TLS); false for 587 (STARTTLS)
SMTP_SECURE=false
# Optional overrides — defaults to contact@luxoriadrive.com from src/config/webSiteConfig.ts
SMTP_USER=contact@luxoriadrive.com
# Set the mailbox password (leave out of git)
SMTP_PASS=
# From address (must match/allow SMTP_USER on the mail server)
SMTP_FROM="Luxoria Drive <contact@luxoriadrive.com>"
# Where booking notifications land
MAIL_TO=contact@luxoriadrive.com
